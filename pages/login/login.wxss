/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  background: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.logo-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #07c160;
}

.title {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.login-form {
  width: 85%;
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.input-group {
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.input-group input {
  font-size: 32rpx;
  color: #333;
}

.login-btn {
  background: #07c160;
  color: white;
  border-radius: 12rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
  margin-top: 20rpx;
}

.login-btn:active {
  background: #05a050;
}

.login-options {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #07c160;
}