/* pages/register/register.wxss */
.register-container {
  padding: 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.form-item input {
  font-size: 30rpx;
  color: #333;
}

.code-item {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.code-item input {
  flex: 1;
  min-width: 200rpx;
}

.code-btn {
  width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  background: #07c160;
  color: white;
  border-radius: 8rpx;
  padding: 0;
  margin: 0;
}

.code-btn[disabled] {
  background: #ccc;
  color: white;
}

.submit-btn {
  background: #07c160;
  color: white;
  border-radius: 12rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
  margin-top: 40rpx;
}

.login-link {
  text-align: center;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #07c160;
}