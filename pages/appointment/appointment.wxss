/* pages/appointment/appointment.wxss */
.service-summary {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.service-summary image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.summary-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.summary-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.summary-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.row-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-row input, .picker-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  color: #999;
}

.textarea-row {
  align-items: flex-start;
  flex-direction: column;
  border-bottom: none;
}

.textarea-row textarea {
  width: 100%;
  height: 160rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #333;
}

.submit-btn {
  background: #07c160;
  color: white;
  border-radius: 12rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
  margin-top: 40rpx;
}