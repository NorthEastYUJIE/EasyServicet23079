/* pages/my-appointment/my-appointment.wxss */
.tab-bar {
  white-space: nowrap;
  background: white;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.login-tip {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}

.login-tip button {
  margin-top: 30rpx;
  width: 200rpx;
  background: #07c160;
  color: white;
}

.appointment-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.card-header image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 24rpx;
  color: #666;
}

/* 状态标签颜色 */
.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 待确认 - 橙色 */
.status-0 {
  background: #fff7e6;
  color: #fa8c16;
}

/* 已接单 - 蓝色 */
.status-1 {
  background: #e6f7ff;
  color: #1890ff;
}

/* 已完成 - 绿色 */
.status-2 {
  background: #f6ffed;
  color: #52c41a;
}

/* 已取消 - 灰色 */
.status-3 {
  background: #f5f5f5;
  color: #999999;
}

.card-body {
  display: flex;
  flex-direction: column;
}

.card-body text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
}

.cancel-btn {
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  background: white;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 8rpx;
  padding: 0;
}

.loading-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 30rpx;
}