<!-- pages/my-appointment/my-appointment.wxml -->
<view class="container">
  <!-- 状态筛选 -->
  <scroll-view class="tab-bar" scroll-x>
    <view class="tab-item {{status === item.value ? 'active' : ''}}" 
          wx:for="{{tabs}}" 
          wx:key="label"
          bindtap="onTabChange"
          data-value="{{item.value}}">
      <text>{{item.label}}</text>
      <view class="tab-line" wx:if="{{status === item.value}}"></view>
    </view>
  </scroll-view>

  <!-- 未登录提示 -->
  <view class="login-tip" wx:if="{{!appointments.length && !loading}}">
    <text>暂无预约记录</text>
    <button bindtap="goLogin" wx:if="{{!userId}}">去登录</button>
  </view>

  <!-- 预约列表 -->
  <view class="appointment-list">
    <view class="appointment-card" wx:for="{{appointments}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
      <view class="card-header">
        <image src="{{item.coverUrl}}" mode="aspectFill"/>
        <view class="header-info">
          <text class="service-name">{{item.serviceName}}</text>
          <text class="order-time">{{item.orderTime}} {{item.timeSlot}}</text>
        </view>
        <!-- 状态标签 -->
        <view class="status-tag status-{{item.status}}">
          {{item.status == 0 ? '待确认' : item.status == 1 ? '已接单' : item.status == 2 ? '已完成' : '已取消'}}
        </view>
      </view>
      
      <view class="card-body">
        <text>联系人：{{item.username}}</text>
        <text>电话：{{item.phone}}</text>
        <text wx:if="{{item.remark}}">备注：{{item.remark}}</text>
      </view>
      
      <!-- 只有待确认(status==0)才能取消 -->
      <view class="card-footer" wx:if="{{item.status == 0}}">
        <button class="cancel-btn" bindtap="cancelAppointment" data-id="{{item.id}}">取消预约</button>
      </view>
    </view>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{!loading && appointments.length === 0 && allAppointments.length > 0}}">
    该状态下暂无预约
  </view>
</view>