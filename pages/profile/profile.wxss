/* pages/profile/profile.wxss */
.profile-card {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-default text {
  font-size: 48rpx;
  color: white;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.username {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.edit-btn {
  font-size: 40rpx;
  color: rgba(255,255,255,0.8);
}

.menu-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.logout-btn {
  margin-top: 60rpx;
  background: white;
  color: #ff4d4f;
  border-radius: 16rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  border: 2rpx solid #ff4d4f;
}