/* pages/service-list/service-list.wxss */
.header-bar {
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.service-item {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.service-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.service-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.service-address {
  font-size: 24rpx;
  color: #666;
}

.service-provider {
  font-size: 24rpx;
  color: #999;
}

.loading-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 30rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}