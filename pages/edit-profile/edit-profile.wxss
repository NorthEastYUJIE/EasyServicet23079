/* pages/edit-profile/edit-profile.wxss */
.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 0 30rpx;
}

.avatar-row, .form-row {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.avatar-row {
  height: 120rpx;
}

.row-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #333;
}

.avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-left: auto;
  margin-right: 20rpx;
}

.avatar-preview-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  margin-right: 20rpx;
}

.avatar-emoji {
  font-size: 48rpx;
}

.row-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.form-row input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
}

.save-btn {
  margin-top: 60rpx;
  background: #07c160;
  color: white;
  border-radius: 12rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
}