/* pages/nearby/nearby.wxss */
.container {
  padding: 20rpx;
}

.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.radius-box {
  display: flex;
  align-items: center;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
}

.radius-input {
  width: 100rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  margin: 0 8rpx;
}

.unit {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.confirm-btn {
  background: #07c160;
  color: white;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.sort-btn {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.sort-arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #07c160;
}

.service-item {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.service-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.service-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.service-address {
  font-size: 24rpx;
  color: #666;
}

.service-provider {
  font-size: 24rpx;
  color: #999;
}

.service-distance {
  font-size: 24rpx;
  color: #07c160;
  font-weight: bold;
}

.loading-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 30rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}