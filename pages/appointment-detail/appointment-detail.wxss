/* pages/appointment-detail/appointment-detail.wxss */
.status-bar {
  text-align: center;
  padding: 40rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.status-bar text {
  font-size: 40rpx;
  font-weight: bold;
}

.detail-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.detail-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.action-area {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 80%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.action-btn.cancel {
  background: white;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.action-btn.primary {
  background: #07c160;
  color: white;
}